{
	"$schema": "https://turbo.build/schema.json",
	"globalEnv": [
		"DATABASE_URL",
		"JWT_SECRET",
		"API_URL"
	],
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"]
		}
	}
}
